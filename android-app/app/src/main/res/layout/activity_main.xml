<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void"
    android:fitsSystemWindows="true">

    <!-- top bar: wordmark + settings -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WY GLASS"
                android:textColor="@color/signal"
                android:fontFamily="@font/space_grotesk_bold"
                android:textSize="17sp"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="assistente óptico · ble link"
                android:textColor="@color/ink_faint"
                android:fontFamily="monospace"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/settingsButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/panel_bg"
            android:text="⚙"
            android:textColor="@color/ink_dim"
            android:textSize="18sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- centerpiece: reticle-framed lens -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="260dp">

            <View
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:background="@drawable/ring_outer" />

            <View
                android:id="@+id/pulseRing"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:background="@drawable/ring_shape"
                android:visibility="invisible" />

            <ImageView
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_reticle"
                android:contentDescription="@null" />

            <ImageView
                android:layout_width="200dp"
                android:layout_height="126dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_glasses"
                android:contentDescription="@string/app_name" />
        </FrameLayout>

        <TextView
            style="@style/Eyebrow"
            android:layout_marginTop="26dp"
            android:text="estado" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="DESCONECTADO"
            android:textColor="@color/alert"
            android:fontFamily="@font/space_grotesk_bold"
            android:textSize="19sp"
            android:letterSpacing="0.06" />

        <TextView
            android:id="@+id/subStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="@color/ink_dim"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:gravity="center"
            android:maxWidth="280dp" />
    </LinearLayout>

    <!-- bottom: last transcript, terminal-style readout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="22dp"
        android:orientation="horizontal"
        android:background="@drawable/terminal_bg"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&gt;"
            android:textColor="@color/signal"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/lastHeardText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="@color/ink_dim"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:maxLines="3" />
    </LinearLayout>

</RelativeLayout>
