<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07090b">

    <TextView
        android:id="@+id/settingsButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:padding="10dp"
        android:text="⚙"
        android:textColor="#8fa3a8"
        android:textSize="26sp"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginTop="24dp"
        android:layout_centerHorizontal="true"
        android:text="WY GLASS"
        android:textColor="#28f5e0"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="180dp">

            <View
                android:id="@+id/pulseRing"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:background="@drawable/ring_shape"
                android:visibility="invisible" />

            <ImageView
                android:layout_width="220dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_glasses"
                android:contentDescription="@string/app_name" />
        </FrameLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="DESCONECTADO"
            android:textColor="#ff4d6a"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/subStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="#516066"
            android:textSize="12sp"
            android:gravity="center"
            android:maxWidth="280dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/lastHeardText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:text=""
        android:textColor="#516066"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:maxLines="3" />

</RelativeLayout>
